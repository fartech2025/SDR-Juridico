# Copie este arquivo para .env e preencha as chaves

# Claude API — proxy local para o browser (nunca expor no frontend)
ANTHROPIC_API_KEY=sk-ant-...

# DataJud (CNJ) — chave pública rotacionada. Sempre verificar em:
# https://datajud-wiki.cnj.jus.br/api-publica/acesso/
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# cpfcnpj.com.br — fallback pago para CPF → nome (R$0,17/consulta, Package 1)
# Deixe em branco para desativar o fallback pago
# Cadastro: https://www.cpfcnpj.com.br/dev/
CPFCNPJ_API_KEY=

# MNI (Modelo Nacional de Interoperabilidade) — credenciais de advogado no PJe
# CPF e senha do advogado cadastrado no PJe do tribunal alvo.
# Quando configurado, habilita o endpoint POST /mni/processo que retorna dados
# completos incluindo partes com nomes (campo não disponível no DataJud público).
# Tribunais suportados: TJMG, TJBA, TJCE, TJDFT, TJGO, TJMA, TJMS, TJMT, TJPA,
#   TJPE, TJPR, TJRJ, TJRS, TJSE, TJAL, TJPI, TJRO, TJTO, TRF3, TRF6,
#   TRT1, TRT2, TRT3, TRT6, TRT9, TRT15, STJ, TST
# Deixe em branco para desativar (DataJud continuará funcionando como fallback)
MNI_CPF=000.000.000-00
MNI_SENHA=
